<section class="arks-shop-shell">
  <section class="arks-shop-shell__toolbar">
    <label class="arks-shop-shell__field">
      <span>{{localize "ARKSSHOP.CharacterLabel"}}</span>
      <select name="actorId">
        {{#each characters}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
        {{/each}}
      </select>
    </label>

    <label class="arks-shop-shell__field">
      <span>{{localize "ARKSSHOP.SearchLabel"}}</span>
      <input type="search" name="search" value="{{searchTerm}}" placeholder="{{localize 'ARKSSHOP.SearchPlaceholder'}}">
    </label>

    <div class="arks-shop-shell__wallet">
      <span>{{localize "ARKSSHOP.AvailableGold"}}</span>
      <strong>{{selectedActorGold}} gp</strong>
    </div>
  </section>

  <section class="arks-shop-shell__filters">
    <div class="arks-shop-filter-tags">
      {{#each compendiumFilters}}
        <button
          type="button"
          class="arks-shop-filter-tag arks-shop-filter-tag--compendium {{#if active}}is-active{{else}}is-inactive{{/if}}"
          data-action="toggle-filter"
          data-filter-group="compendium"
          data-filter-id="{{id}}"
          aria-pressed="{{#if active}}true{{else}}false{{/if}}"
        >
          {{label}}
        </button>
      {{/each}}

      {{#each availabilityFilters}}
        <button
          type="button"
          class="arks-shop-filter-tag arks-shop-filter-tag--availability {{#if active}}is-active{{else}}is-inactive{{/if}}"
          data-action="toggle-filter"
          data-filter-group="availability"
          data-filter-id="{{id}}"
          aria-pressed="{{#if active}}true{{else}}false{{/if}}"
        >
          {{label}}
        </button>
      {{/each}}

      {{#each typeFilters}}
        <button
          type="button"
          class="arks-shop-filter-tag arks-shop-filter-tag--type {{#if active}}is-active{{else}}is-inactive{{/if}}"
          data-action="toggle-filter"
          data-filter-group="type"
          data-filter-id="{{id}}"
          aria-pressed="{{#if active}}true{{else}}false{{/if}}"
        >
          {{label}}
        </button>
      {{/each}}
    </div>
  </section>

  {{#unless hasCharacters}}
    <section class="arks-shop-shell__empty">
      <p>{{localize "ARKSSHOP.EmptyCharacters"}}</p>
    </section>
  {{/unless}}

  {{#unless hasItems}}
    <section class="arks-shop-shell__empty">
      <p>{{localize "ARKSSHOP.EmptyInventory"}}</p>
    </section>
  {{/unless}}

  {{#if hasItems}}
    <section class="arks-shop-shell__inventory">
      {{#each items}}
        <article
          class="arks-shop-item"
          data-item-uuid="{{uuid}}"
          data-search="{{searchText}}"
          data-compendium="{{sourceCollection}}"
          data-item-type="{{type}}"
          data-base-price-copper="{{priceCopper}}"
          data-can-purchase="{{#if canPurchase}}true{{else}}false{{/if}}"
        >
          <div class="arks-shop-item__image" style="background-image: url({{img}})"></div>

          <div class="arks-shop-item__details">
            <button type="button" class="arks-shop-item__name" data-action="open-source">{{name}}</button>
            <div class="arks-shop-item__meta">{{typeLabel}} | {{sourceLabel}}</div>

            {{#if hasMasterworkOptions}}
              <label class="arks-shop-item__variant">
                <span>{{localize "ARKSSHOP.Masterwork.Label"}}</span>
                <select name="masterwork">
                  <option value="" data-price-adjustment-copper="0" data-summary="">
                    {{localize "ARKSSHOP.Masterwork.Standard"}}
                  </option>
                  {{#each masterworkOptions}}
                    <option
                      value="{{id}}"
                      data-price-adjustment-copper="{{priceDeltaCopper}}"
                      data-summary="{{summary}}"
                    >
                      {{label}}
                    </option>
                  {{/each}}
                </select>
              </label>
              <div class="arks-shop-item__variant-summary" data-role="masterwork-summary"></div>
            {{/if}}
          </div>

          <div class="arks-shop-item__price" data-role="item-price">{{formattedPrice}} gp</div>

          <div class="arks-shop-item__controls">
            <input type="number" name="quantity" min="1" step="1" value="1">
            <button type="button" data-action="buy-item" {{#unless canPurchase}}disabled{{/unless}}>
              {{localize "ARKSSHOP.Buy"}}
            </button>
          </div>
        </article>
      {{/each}}
    </section>
  {{/if}}
</section>
